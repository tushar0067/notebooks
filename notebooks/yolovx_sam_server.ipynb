    {
      "cell_type": "markdown",
        "source": [
        "# 🔥 YOLOvX — SAM2 Inference Server (Multi-Point)\n",
        "> Auto-generated by your annotation platform. Just run all cells!\n",
        "\n",
        "**Requirements:** GPU runtime (T4 recommended)\n",
        "\n",
        "Runtime → Change runtime type → T4 GPU → Save\n"
        ]  
      "id": "cell-0",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": [
        "# ⚡ CELL 1 — Install & Setup (Run Once per Session)\n",
        "!pip install -q fastapi uvicorn python-multipart requests opencv-python-headless\n",
        "!pip install -q git+https://github.com/facebookresearch/segment-anything-2.git\n",
        "\n",
        "import os\n",
        "\n",
        "# Download SAM2 model weights (cached after first run)\n",
        "if not os.path.exists('sam2_hiera_large.pt'):\n",
        "    os.system('wget -q https://dl.fbaipublicfiles.com/segment_anything_2/072824/sam2_hiera_large.pt')\n",
        "    print('✅ Model downloaded.')\n",
        "else:\n",
        "    print('✅ Model cached, skipping download.')\n",
        "\n",
        "# Download cloudflared tunnel binary (cached after first run)\n",
        "if not os.path.exists('cloudflared-linux-amd64'):\n",
        "    os.system('wget -q -nc https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64')\n",
        "    os.system('chmod +x cloudflared-linux-amd64')\n",
        "    print('✅ Cloudflared ready.')\n",
        "else:\n",
        "    print('✅ Cloudflared cached.')\n",
        "\n",
        "# ─────────────────────────────────────────────────────────────────\n",
        "# Write server.py\n",
        "# ─────────────────────────────────────────────────────────────────\n",
        "SUPABASE_URL = \"https://base.wiserly.org/\"\n",
        "\n",
        "server_code = '''\n",
        "import os, cv2, numpy as np, requests\n",
        "from fastapi import FastAPI, HTTPException\n",
        "from fastapi.middleware.cors import CORSMiddleware\n",
        "from sam2.build_sam import build_sam2\n",
        "from sam2.sam2_image_predictor import SAM2ImagePredictor\n",
        "from pydantic import BaseModel\n",
        "from typing import List, Optional\n",
        "from PIL import Image\n",
        "from io import BytesIO\n",
        "\n",
        "SUPABASE_URL = \"''' + SUPABASE_URL + '''\"\n",
        "\n",
        "app = FastAPI(title=\"SAM2 Multi-Point Server\")\n",
        "app.add_middleware(\n",
        "    __import__(\"fastapi.middleware.cors\", fromlist=[\"CORSMiddleware\"]).CORSMiddleware,\n",
        "    allow_origins=[\"*\"],\n",
        "    allow_methods=[\"*\"],\n",
        "    allow_headers=[\"*\"],\n",
        ")\n",
        "\n",
        "# ── Load model ───────────────────────────────────────────────────\n",
        "print(\"Loading SAM2 model...\")\n",
        "sam2_model = build_sam2(\"sam2_hiera_l.yaml\", \"sam2_hiera_large.pt\", device=\"cuda\")\n",
        "predictor = SAM2ImagePredictor(sam2_model)\n",
        "print(\"SAM2 ready.\")\n",
        "\n",
        "# Image cache — avoids re-encoding the same image on every click\n",
        "current_img_id = None\n",
        "current_img_shape = None\n",
        "\n",
        "\n",
        "# ── Request schema ───────────────────────────────────────────────\n",
        "class SegmentRequest(BaseModel):\n",
        "    image_path: str\n",
        "    # Multi-point: list of [x, y] pairs\n",
        "    point_coords: List[List[float]]\n",
        "    # 1 = positive (include), 0 = negative (exclude)\n",
        "    point_labels: List[int]\n",
        "    # Optional quality hint (ignored server-side, reserved for future)\n",
        "    quality: Optional[str] = \"medium\"\n",
        "\n",
        "\n",
        "def load_image(image_path: str) -> np.ndarray:\n",
        "    \"\"\"Download image from Supabase storage or any full URL.\"\"\"\n",
        "    full_url = (\n",
        "        image_path if image_path.startswith(\"http\")\n",
        "        else f\"{SUPABASE_URL.rstrip(\\'/')}/storage/v1/object/public/datasets/{image_path}\"\n",
        "    )\n",
        "    resp = requests.get(full_url, timeout=15)\n",
        "    resp.raise_for_status()\n",
        "    return np.array(Image.open(BytesIO(resp.content)).convert(\"RGB\"))\n",
        "\n",
        "\n",
        "def mask_to_polygon(mask: np.ndarray, epsilon_factor: float = 0.005) -> List[float]:\n",
        "    \"\"\"Convert binary mask → simplified polygon point list [x, y, x, y, ...].\"\"\"\n",
        "    m8 = mask.astype(np.uint8) * 255\n",
        "    blurred = cv2.GaussianBlur(m8, (7, 7), 0)\n",
        "    _, binary = cv2.threshold(blurred, 127, 255, cv2.THRESH_BINARY)\n",
        "    contours, _ = cv2.findContours(binary, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
        "    if not contours:\n",
        "        return []\n",
        "    largest = max(contours, key=cv2.contourArea)\n",
        "    epsilon = epsilon_factor * cv2.arcLength(largest, True)\n",
        "    approx = cv2.approxPolyDP(largest, epsilon, True)\n",
        "    return approx.flatten().tolist()\n",
        "\n",
        "\n",
        "# ── Endpoints ────────────────────────────────────────────────────\n",
        "@app.get(\"/health\")\n",
        "def health():\n",
        "    return {\n",
        "        \"status\": \"ok\",\n",
        "        \"model\": \"sam2_hiera_large\",\n",
        "        \"multi_point\": True,\n",
        "        \"current_image\": current_img_id,\n",
        "    }\n",
        "\n",
        "\n",
        "@app.post(\"/segment\")\n",
        "async def segment(req: SegmentRequest):\n",
        "    global current_img_id, current_img_shape\n",
        "\n",
        "    # Validate points\n",
        "    if not req.point_coords or not req.point_labels:\n",
        "        raise HTTPException(status_code=422, detail=\"point_coords and point_labels are required\")\n",
        "    if len(req.point_coords) != len(req.point_labels):\n",
        "        raise HTTPException(status_code=422, detail=\"point_coords and point_labels must have the same length\")\n",
        "    for label in req.point_labels:\n",
        "        if label not in (0, 1):\n",
        "            raise HTTPException(status_code=422, detail=\"point_labels must be 0 (negative) or 1 (positive)\")\n",
        "\n",
        "    # Load & encode image (cached per image_path)\n",
        "    if current_img_id != req.image_path:\n",
        "        try:\n",
        "            img = load_image(req.image_path)\n",
        "            current_img_shape = img.shape\n",
        "            predictor.set_image(img)\n",
        "            current_img_id = req.image_path\n",
        "        except Exception as e:\n",
        "            raise HTTPException(status_code=500, detail=f\"Image load failed: {str(e)}\")\n",
        "\n",
        "    orig_h, orig_w = current_img_shape[:2]\n",
        "\n",
        "    # Clamp all points to image bounds\n",
        "    coords = np.array([\n",
        "        [np.clip(p[0], 0, orig_w - 1), np.clip(p[1], 0, orig_h - 1)]\n",
        "        for p in req.point_coords\n",
        "    ], dtype=np.float32)\n",
        "    labels = np.array(req.point_labels, dtype=np.int32)\n",
        "\n",
        "    # Run SAM2 with all points at once\n",
        "    masks, scores, _ = predictor.predict(\n",
        "        point_coords=coords,\n",
        "        point_labels=labels,\n",
        "        multimask_output=True,\n",
        "    )\n",
        "\n",
        "    # Pick highest-scoring mask\n",
        "    best_idx = int(np.argmax(scores))\n",
        "    best_mask = masks[best_idx]\n",
        "\n",
        "    polygon = mask_to_polygon(best_mask)\n",
        "\n",
        "    return {\n",
        "        \"polygon\": polygon,\n",
        "        \"image_size\": [orig_w, orig_h],\n",
        "        \"score\": float(scores[best_idx]),\n",
        "        \"num_points\": len(req.point_coords),\n",
        "        \"positive_points\": int(sum(labels)),\n",
        "        \"negative_points\": int(len(labels) - sum(labels)),\n",
        "    }\n",
        "'''\n",
        "\n",
        "with open('server.py', 'w') as f:\n",
        "    f.write(server_code)\n",
        "\n",
        "print('\\n✅ Setup complete! Run Cell 2 to start the server.')"
      ],
      "id": "cell-1",
      "metadata": {},
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 🚀 Cell 2 — Start Server\n",
        "Run this every time you open the notebook. Takes ~30 seconds to load the model.\n",
        "\n",
        "**Copy the `trycloudflare.com` URL** that appears and paste it into your app."
      ],
      "id": "cell-2",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": [
        "# 🚀 CELL 2 — Start Inference Server\n",
        "import threading, uvicorn, subprocess, time, re, sys\n",
        "sys.path.insert(0, '.')\n",
        "\n",
        "TUNNEL_URL = None\n",
        "\n",
        "def start_tunnel():\n",
        "    global TUNNEL_URL\n",
        "    p = subprocess.Popen(\n",
        "        ['./cloudflared-linux-amd64', 'tunnel', '--url', 'http://localhost:8000'],\n",
        "        stdout=subprocess.PIPE,\n",
        "        stderr=subprocess.PIPE\n",
        "    )\n",
        "    time.sleep(3)\n",
        "    for line in iter(p.stderr.readline, b''):\n",
        "        line = line.decode('utf-8')\n",
        "        if '.trycloudflare.com' in line:\n",
        "            m = re.search(r'https://[a-zA-Z0-9-]+\\.trycloudflare\\.com', line)\n",
        "            if m:\n",
        "                TUNNEL_URL = m.group(0)\n",
        "                print(f'\\n🔥 COPY THIS URL INTO YOUR APP:\\n\\n  {TUNNEL_URL}\\n')\n",
        "                print('Multi-point segmentation is ready.')\n",
        "                print('Positive clicks → label 1 | Shift+click (negative) → label 0')\n",
        "                break\n",
        "\n",
        "def run_server():\n",
        "    import server\n",
        "    uvicorn.run(server.app, host='0.0.0.0', port=8000, log_level='warning')\n",
        "\n",
        "print('🚀 Starting SAM2 multi-point server...')\n",
        "threading.Thread(target=start_tunnel, daemon=True).start()\n",
        "threading.Thread(target=run_server, daemon=True).start()\n",
        "\n",
        "try:\n",
        "    while True:\n",
        "        time.sleep(1)\n",
        "except KeyboardInterrupt:\n",
        "    print('Stopped.')"
      ],
      "id": "cell-3",
      "metadata": {},
      "outputs": [],
      "execution_count": null
    },
